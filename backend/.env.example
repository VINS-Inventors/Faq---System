PORT=5000
MONGO_URI=mongodb://localhost:27017/faq-system
JWT_SECRET=your-secret-here
PG_URI=postgresql://postgres:password@localhost:5432/faq_system

# ── Email / Password Reset ──────────────────────────────────────────────────
# EMAIL_SERVICE: 'gmail' or any SMTP service nodemailer supports
# Leave EMAIL_USER / EMAIL_PASS blank to log reset links to console (dev mode).
# For Gmail: use an App Password (not your real password)
#   → https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Link validity in minutes (default 15)
RESET_TOKEN_EXPIRY_MIN=15

# Frontend base URL used in reset email links
FRONTEND_URL=http://localhost:3000